# Which provider profile to run.
#   dev-free  → Google Gemini free tier (~$0)   [default]
#   quality   → Claude Opus 4.8 (a few cents/report; use to judge real quality)
PROVIDER_PROFILE=dev-free

# dev-free profile — free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# quality profile — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Web research — free 1,000/mo at https://tavily.com
TAVILY_API_KEY=

# Shopping / live prices — free 2,500 at https://serper.dev
SERPER_API_KEY=
