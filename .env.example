# Provider profile: dev-free (Gemini Flash, ~$0) | dev-pro (Gemini 2.5 Pro) | quality (Claude Opus 4.8)
PROVIDER_PROFILE=dev-free

GOOGLE_GENERATIVE_AI_API_KEY=   # dev-free / dev-pro — https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=              # quality profile — https://console.anthropic.com
TAVILY_API_KEY=                 # web research (free 1k/mo) — https://tavily.com
SERPER_API_KEY=                 # shopping / prices (free 2,500) — https://serper.dev
YOUTUBE_API_KEY=                # optional review videos — Google Cloud console

# Database (Phase 0 schema target). Local: postgres://postgres:postgres@localhost:5432/scout
DATABASE_URL=

# Phase 2 watch/notify — email alerts via Resend (https://resend.com). No key → console no-op channel.
RESEND_API_KEY=                 # email delivery for watch alerts
RESEND_FROM=                    # optional override, e.g. "Scout <alerts@yourdomain.com>" (domain must be verified)
